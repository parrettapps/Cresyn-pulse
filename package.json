{
  "name": "cresyn-pulse",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:security": "turbo run test:security",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore",
    "db:generate": "pnpm --filter @cresyn/db generate",
    "db:migrate": "pnpm --filter @cresyn/db migrate",
    "db:studio": "pnpm --filter @cresyn/db studio"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.5.0",
    "tsx": "^4.21.0",
    "turbo": "^2.5.0",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "overrides": {
      "drizzle-orm": "^0.45.1"
    },
    "onlyBuiltDependencies": [
      "argon2",
      "esbuild",
      "msgpackr-extract",
      "sharp",
      "unrs-resolver"
    ]
  }
}
