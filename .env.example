# ============================================================
# CRESYN PULSE — Environment Variables
# Copy this to .env and fill in values. NEVER commit .env
# ============================================================

# ---- DATABASE ----
DATABASE_URL="postgresql://postgres:password@localhost:5432/cresyn_pulse_dev"

# ---- REDIS ----
REDIS_URL="redis://localhost:6379"

# ---- AUTH (Better Auth) ----
BETTER_AUTH_SECRET="generate-with: openssl rand -base64 32"
BETTER_AUTH_URL="http://localhost:3001"

# ---- GOOGLE OAUTH ----
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---- MICROSOFT OAUTH (Entra ID) ----
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT_ID="common"

# ---- JWT ----
JWT_SECRET="generate-with: openssl rand -base64 64"

# ---- CLOUDFLARE R2 ----
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="cresyn-pulse-dev"
R2_PUBLIC_URL=""

# ---- STRIPE ----
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ---- RESEND (Email) ----
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@cresyn.com"

# ---- SENTRY ----
SENTRY_DSN=""

# ---- POSTHOG ----
POSTHOG_KEY=""
POSTHOG_HOST="https://us.i.posthog.com"

# ---- APP ----
NODE_ENV="development"
API_PORT=3001
WEB_URL="http://localhost:3000"
API_URL="http://localhost:3001"

# ---- PLATFORM ADMIN ----
# Email address(es) that get platform_admin role on first login
PLATFORM_ADMIN_EMAILS=""
