{
  "name": "@cresyn/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:security": "vitest run tests/security"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.740.0",
    "@aws-sdk/s3-request-presigner": "^3.740.0",
    "@cresyn/config": "workspace:*",
    "@cresyn/db": "workspace:*",
    "@cresyn/types": "workspace:*",
    "@cresyn/validation": "workspace:*",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/rate-limit": "^10.2.0",
    "@sentry/node": "^8.50.0",
    "argon2": "^0.43.0",
    "better-auth": "^1.4.19",
    "bullmq": "^5.40.0",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.2.0",
    "file-type": "^20.4.1",
    "ioredis": "^5.5.0",
    "isomorphic-dompurify": "^2.21.0",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "resend": "^4.1.2",
    "stripe": "^17.7.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.8",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.0",
    "vitest": "^3.0.5"
  }
}
